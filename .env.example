# LLM (configure at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Embedding
EMBEDDING_PROVIDER=cloud
SILICONFLOW_API_KEY=

# App
DEFAULT_LLM_MODEL=gpt-4o
BACKEND_PORT=8000
FRONTEND_PORT=3000

# OCR fallback for low-quality PDF text extraction
# none | paddle
OCR_PROVIDER=none
OCR_DPI=120
OCR_DETECTION_MODEL=PP-OCRv5_mobile_det
OCR_RECOGNITION_MODEL=PP-OCRv5_mobile_rec
OCR_CACHE_DIR=data/cache/paddlex
